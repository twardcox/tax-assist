# ── UTBIS Environment Variables ───────────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# Never commit .env with real keys to version control.
#
# Load before starting the server:
#   PowerShell:  Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [System.Environment]::SetEnvironmentVariable($Matches[1].Trim(), $Matches[2].Trim()) } }
#   bash:        export $(grep -v '^#' .env | xargs)

