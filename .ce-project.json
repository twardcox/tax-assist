{
  "toolkit": {
    "hooks": {
      "preCommit": {
        "enabled": true,
        "lintStaged": false,
        "typeCheck": false,
        "runTests": false
      },
      "commitMsg": {
        "enabled": true,
        "requireTicket": false
      },
      "prePush": {
        "enabled": true,
        "validateBranch": false
      },
      "postCheckout": {
        "enabled": true
      }
    },
    "ci": {
      "linting": true,
      "formatting": false,
      "typeCheck": true,
      "unitTests": true,
      "e2eTests": false
    }
  }
}
